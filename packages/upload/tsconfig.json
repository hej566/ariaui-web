{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/.tsbuildinfo",
    "paths": {
      "@ariaui-web/*": ["../*/dist/index.d.ts"]
    }
  },
  "include": [
    "index.ts",
    "src/**/*.ts",
    "__test__/**/*.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
